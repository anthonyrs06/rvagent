# --- Required ---------------------------------------------------------------
# Signs viewer/admin session cookies. Generate: openssl rand -hex 32
SESSION_SECRET=
# Single-owner password for /admin
OWNER_PASSWORD=
# Salt for IP/UA hashing (defaults to SESSION_SECRET if unset)
IP_HASH_SALT=

# Where the SQLite db + rasterized pages live (default ./data)
DATA_DIR=./data

# --- Optional integrations (features off when unset) -------------------------
# Slack incoming webhook — "your resume was opened" + security alerts
SLACK_WEBHOOK_URL=

# Cloudflare Turnstile (invisible bot challenge on the viewer gate)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# PostHog — client-side (VITE_PUBLIC_ prefix is baked into the browser bundle)
VITE_PUBLIC_POSTHOG_TOKEN=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# PostHog — server-side mirror capture (defaults to the VITE_PUBLIC_ values)
POSTHOG_TOKEN=
POSTHOG_HOST=
# PostHog — dashboard HogQL queries (personal API key, NOT the project token)
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
